# Produção / build: URL pública da API
VITE_API_URL=http://localhost:8000

# Dev: alvo do proxy Vite (/api → backend). No celular use o IP da máquina só se o PHP escutar nesse host.
# Na prática, deixe http://127.0.0.1:8000 e use `php artisan serve --host=0.0.0.0`.
VITE_PROXY_TARGET=http://127.0.0.1:8000

VITE_AUTH_COOKIE_NAME=auth_token

# Cookies de auth são configurados no .env do BACKEND (AUTH_COOKIE_*), não aqui.
